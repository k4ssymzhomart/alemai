# SQLAlchemy/psycopg connection string; inside docker-compose the api uses host "db" instead of "localhost"
DATABASE_URL=postgresql+psycopg://igerim:igerim@localhost:55432/igerim

# RapidAPI key for the copilot LLM (GPT-4o-mini wrapper, docs/11 P8); the lead pastes it locally.
# Leave empty to run with canned answers (LLM_MODE=canned). NEVER commit a real key.
RAPIDAPI_KEY=

# Base URL the Next.js frontend uses to reach the FastAPI backend
NEXT_PUBLIC_API_BASE=http://localhost:8800/api/v1
